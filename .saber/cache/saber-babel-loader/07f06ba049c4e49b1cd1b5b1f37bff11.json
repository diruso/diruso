{"ast":null,"code":"//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\nimport variables from 'saber/variables';\nimport Header from '../components/Header';\nimport Footer from '../components/Footer';\nimport defaults from '../constants/defaults.yml';\nimport formatDate from '../scripts/formatDate';\nexport default {\n  props: ['page'],\n  components: {\n    Header,\n    Footer\n  },\n\n  head() {\n    const {\n      title,\n      layout,\n      excerpt\n    } = this.page.attributes;\n    let {\n      description\n    } = this.$siteConfig;\n\n    if (layout === 'page' || layout === 'post') {\n      if (excerpt) {\n        description = excerpt.replace(/<(?:.|\\n)*?>/gm, '');\n      }\n    }\n\n    return {\n      title: title ? `${title} » ${this.siteTitle}` : this.siteTitle,\n      meta: [description && {\n        name: 'description',\n        content: description\n      }].filter(Boolean),\n      link: this.$feed ? [{\n        rel: 'alternate',\n        title: `${this.siteTitle} - Feed`,\n        type: `application/${this.$feed.type === 'atom' ? 'atom+xml' : this.$feed.type === 'rss' ? 'rss+xml' : 'json'}`,\n        href: this.$feed.permalink\n      }, {\n        rel: 'stylesheet',\n        media: 'all',\n        href: '//cdnjs.cloudflare.com/ajax/libs/Han/3.3.0/han.min.css'\n      }].filter(Boolean) : [],\n      script: [// FontAwesome\n      {\n        src: 'https://kit.fontawesome.com/9e8cab954f.js',\n        crossorigin: 'anonymous'\n      }]\n    };\n  },\n\n  computed: {\n    siteTitle() {\n      return this.$siteConfig.title;\n    },\n\n    description() {\n      return this.$siteConfig.description;\n    }\n\n  },\n  methods: {\n    formatDate\n  }\n};","map":{"version":3,"sources":["Base.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;AAuBA,OAAA,SAAA,MAAA,iBAAA;AACA,OAAA,MAAA,MAAA,sBAAA;AACA,OAAA,MAAA,MAAA,sBAAA;AAEA,OAAA,QAAA,MAAA,2BAAA;AAEA,OAAA,UAAA,MAAA,uBAAA;AAEA,eAAA;AACA,EAAA,KAAA,EAAA,CAAA,MAAA,CADA;AAEA,EAAA,UAAA,EAAA;AAAA,IAAA,MAAA;AAAA,IAAA;AAAA,GAFA;;AAGA,EAAA,IAAA,GAAA;AACA,UAAA;AAAA,MAAA,KAAA;AAAA,MAAA,MAAA;AAAA,MAAA;AAAA,QAAA,KAAA,IAAA,CAAA,UAAA;AAEA,QAAA;AAAA,MAAA;AAAA,QAAA,KAAA,WAAA;;AACA,QAAA,MAAA,KAAA,MAAA,IAAA,MAAA,KAAA,MAAA,EAAA;AACA,UAAA,OAAA,EAAA;AACA,QAAA,WAAA,GAAA,OAAA,CAAA,OAAA,CAAA,gBAAA,EAAA,EAAA,CAAA;AACA;AACA;;AAEA,WAAA;AACA,MAAA,KAAA,EAAA,KAAA,GAAA,GAAA,KAAA,MAAA,KAAA,SAAA,EAAA,GAAA,KAAA,SADA;AAEA,MAAA,IAAA,EAAA,CAAA,WAAA,IAAA;AACA,QAAA,IAAA,EAAA,aADA;AAEA,QAAA,OAAA,EAAA;AAFA,OAAA,EAGA,MAHA,CAGA,OAHA,CAFA;AAMA,MAAA,IAAA,EAAA,KAAA,KAAA,GAAA,CACA;AACA,QAAA,GAAA,EAAA,WADA;AAEA,QAAA,KAAA,EAAA,GAAA,KAAA,SAAA,SAFA;AAGA,QAAA,IAAA,EAAA,eACA,KAAA,KAAA,CAAA,IAAA,KAAA,MAAA,GACA,UADA,GAEA,KAAA,KAAA,CAAA,IAAA,KAAA,KAAA,GACA,SADA,GAEA,MACA,EATA;AAUA,QAAA,IAAA,EAAA,KAAA,KAAA,CAAA;AAVA,OADA,EAaA;AACA,QAAA,GAAA,EAAA,YADA;AAEA,QAAA,KAAA,EAAA,KAFA;AAGA,QAAA,IAAA,EAAA;AAHA,OAbA,EAkBA,MAlBA,CAkBA,OAlBA,CAAA,GAkBA,EAxBA;AAyBA,MAAA,MAAA,EAAA,CACA;AACA;AACA,QAAA,GAAA,EAAA,2CADA;AAEA,QAAA,WAAA,EAAA;AAFA,OAFA;AAzBA,KAAA;AAiCA,GA9CA;;AA+CA,EAAA,QAAA,EAAA;AACA,IAAA,SAAA,GAAA;AACA,aAAA,KAAA,WAAA,CAAA,KAAA;AACA,KAHA;;AAIA,IAAA,WAAA,GAAA;AACA,aAAA,KAAA,WAAA,CAAA,WAAA;AACA;;AANA,GA/CA;AAuDA,EAAA,OAAA,EAAA;AACA,IAAA;AADA;AAvDA,CAAA","sourcesContent":["<template>\n  <div id=\"app\">\n    <div id=\"top\">\n      <div id=\"topbar\"></div>\n    </div>\n    <div id=\"wrapper\">\n      <Header\n        :siteTitle=\"siteTitle\"\n        :description=\"description\" />\n      <main id=\"container\">\n        <div id=\"content\">\n          <slot></slot>\n        </div>\n      </main>\n      <Footer\n        :siteTitle=\"siteTitle\" />\n      <!-- <script src=\"//cdnjs.cloudflare.com/ajax/libs/Han/3.3.0/han.min.js\"></script> -->\n      <!-- <script type=\"text/javascript\">Han( document.getElementById('content')).render()</script> -->\n    </div>\n  </div>\n</template>\n\n<script>\nimport variables from 'saber/variables'\nimport Header    from '../components/Header'\nimport Footer    from '../components/Footer'\n\nimport defaults from '../constants/defaults.yml'\n\nimport formatDate from '../scripts/formatDate'\n\nexport default {\n  props: ['page'],\n  components: { Header, Footer },\n  head() {\n    const { title, layout, excerpt } = this.page.attributes\n\n    let { description } = this.$siteConfig\n    if (layout === 'page' || layout === 'post') {\n      if (excerpt) {\n        description = excerpt.replace(/<(?:.|\\n)*?>/gm, '')\n      }\n    }\n\n    return {\n      title: title ? `${title} » ${this.siteTitle}` : this.siteTitle,\n      meta: [ description && {\n        name: 'description',\n        content: description\n      }].filter(Boolean),\n      link: this.$feed ? [\n        {\n          rel: 'alternate',\n          title: `${this.siteTitle} - Feed`,\n          type: `application/${\n            this.$feed.type === 'atom'\n              ? 'atom+xml'\n              : this.$feed.type === 'rss'\n              ? 'rss+xml'\n              : 'json'\n          }`,\n          href: this.$feed.permalink\n        }, \n        {\n          rel: 'stylesheet',\n          media: 'all',\n          href: '//cdnjs.cloudflare.com/ajax/libs/Han/3.3.0/han.min.css',\n        }\n      ].filter(Boolean) : [],\n      script: [\n        // FontAwesome\n        {\n          src: 'https://kit.fontawesome.com/9e8cab954f.js',\n          crossorigin: 'anonymous'\n        }\n      ]\n    }\n  },\n  computed: {\n    siteTitle() {\n      return this.$siteConfig.title;\n    },\n    description() {\n      return this.$siteConfig.description;\n    }\n  },\n  methods: {\n    formatDate\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n@import '../styles/main.scss';\n\n#app {\n  // background: $black;\n}\n\n#wrapper {\n  width: 100vw;\n  max-width: 100vw;\n  // padding-top: 10px;\n}\n\n#top {\n  // position: fixed;\n  // width: 100vw;\n  // height: 10px;\n  // background: #0A0A0A;\n}\n\n#container {\n\n}\n\n#content {\n  display: block;\n  position: relative;\n  padding: 21px 0;\n  width: 70vw;\n  max-width: 732px;\n  // margin: 50px auto 0 15vw;\n  margin: 50px auto 0;\n  border-radius: 20px;\n  // background: $dark-0;\n  background: $white;\n  backdrop-filter: blur(20px);\n  // box-shadow: 0px 10px 20px 0px rgba(236, 236, 236, 0.86);\n  box-shadow: rgba(0, 0, 0, 0.15) 0px 20px 40px;\n  // transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0s;\n}\n\n\n</style>\n"],"sourceRoot":"theme/components"},"metadata":{},"sourceType":"module"}