{"ast":null,"code":"//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\n//\nimport handleContact from '../scripts/utils/handleContact';\nexport default {\n  computed: {\n    contact() {\n      return this.$themeConfig.contact || {};\n    },\n\n    feed() {\n      return this.$feed;\n    }\n\n  },\n  methods: {\n    handleContact\n  }\n};","map":{"version":3,"sources":["Contact.vue"],"names":[],"mappings":";;;;;;;;;;;;AAaA,OAAA,aAAA,MAAA,gCAAA;AAEA,eAAA;AACA,EAAA,QAAA,EAAA;AACA,IAAA,OAAA,GAAA;AACA,aAAA,KAAA,YAAA,CAAA,OAAA,IAAA,EAAA;AACA,KAHA;;AAIA,IAAA,IAAA,GAAA;AACA,aAAA,KAAA,KAAA;AACA;;AANA,GADA;AASA,EAAA,OAAA,EAAA;AACA,IAAA;AADA;AATA,CAAA","sourcesContent":["<template>\n  <div class=\"contact\">\n    <ul>\n      <li v-for=\"(item, name, i) in contact\" v-if=\"contact[name]\">\n        <a :href=\"handleContact(name, 'url') + item\" :title=\"contact[name]\">\n          <i :class=\"handleContact(name, 'icon')\"></i>\n        </a>\n      </li>\n    </ul>\n  </div>\n</template>\n\n<script>\nimport handleContact from '../scripts/utils/handleContact';\n\nexport default {\n  computed: {\n    contact() {\n      return this.$themeConfig.contact || {}\n    },\n    feed() {\n      return this.$feed\n    },\n  },\n  methods: {\n    handleContact\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n@import '../styles/main.scss';\n\n.contact {\n  ul {\n    display: flex;\n    justify-content: center;\n    align-items: baseline;\n    margin: 0;\n    padding: 0;\n    list-style: none;\n    li {\n      padding: 0 3px;\n      a, a:link {\n        color: $gray;\n        &:hover, &:active {\n          color: $black;\n          background: transparent;\n        }\n      }\n    }\n  }\n}\n</style>\n"],"sourceRoot":"theme/components"},"metadata":{},"sourceType":"module"}