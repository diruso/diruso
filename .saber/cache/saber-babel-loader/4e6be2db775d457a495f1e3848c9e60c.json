flex;\n    // height: 30px;\n    align-items: flex-end;\n    justify-content: space-between;\n    \n    a, a:link { text-decoration: none; }\n    \n    .nav-info {\n      h1 {\n        margin-bottom: 10px;\n        font-size: 48px;\n        line-height: 48px;\n        color: $blue;\n\n        a.title {\n          // margin: 0 4px;\n          // font-family: 'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;\n          font-size: 42px;\n          font-weight: 900;\n          text-shadow: 0 1px 1px rgba(0, 0, 0, .08);\n          color: $black;\n          \n          // box-shadow: 5px 5px 0 0 $aeon-blue, inset 5px 5px 0 0 $aeon-blue;\n          &:hover, &:active {\n            text-decoration: underline;\n          //   color: $aeon-blue;\n          //   background: #FFF;\n          //   box-shadow: 0 0 0 0 $aeon-yellow, inset 6em 3.5em 0 0 $aeon-yellow;\n          }\n        }\n      }\n    }\n    .nav-bar ul {\n      display: flex;\n      list-style: none;\n      li {\n        margin: 0 5px;\n        // a {\n        //   padding: 21px;\n        //   border-radius: 20px;\n        //   box-shadow: rgba(198, 208, 235, 0.5) 0px 10px 20px;\n        //   border: 1px solid rgb(198, 208, 235);\n        //   transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0s;\n        //   &:hover {\n        //     box-shadow: rgb(198, 208, 235) 0px 30px 60px;\n        //     transform: translateY(-5px);\n        //   }\n        // }\n      }\n    }\n  }\n\n}\n\n\n</style>\n"],"sourceRoot":"theme/components"},"metadata":{},"sourceType":"module"}